     ] ;
     fhir:value [
       a fhir:Code ;
       fhir:v "fhir"
     ]
  ] ) ; # 
  fhir:url [
     fhir:v "http://hl7.org/fhir/CodeSystem/additional-binding-purpose"^^xsd:anyURI ;
