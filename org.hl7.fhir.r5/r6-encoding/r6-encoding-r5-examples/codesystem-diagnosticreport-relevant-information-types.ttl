  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: CodeSystem diagnosticreport-relevant-information-types</b>\n      </p>\n      <a name=\"diagnosticreport-relevant-information-types\"> </a>\n      <a name=\"hcdiagnosticreport-relevant-information-types\"> </a>\n      <div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\">\n        <p style=\"margin-bottom: 0px\"/>\n        <p style=\"margin-bottom: 0px\">Profile: \n          <a href=\"shareablecodesystem.html\">Shareable CodeSystem</a>\n        </p>\n      </div>\n      <p>This case-sensitive code system \n        <code>http://hl7.org/fhir/diagnosticreport-relevant-information-types</code> defines the following codes in a Is-A hierarchy:\n      </p>\n      <table class=\"codes\">\n        <tr>\n          <td>\n            <b>Lvl</b>\n          </td>\n          <td style=\"white-space:nowrap\">\n            <b>Code</b>\n          </td>\n          <td>\n            <b>Display</b>\n          </td>\n          <td>\n            <b>Definition</b>\n          </td>\n        </tr>\n        <tr>\n          <td>1</td>\n          <td style=\"white-space:nowrap\">QST\n            <a name=\"diagnosticreport-relevant-information-types-QST\"> </a>\n          </td>\n          <td>Question</td>\n          <td>Question</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  AOE\n            <a name=\"diagnosticreport-relevant-information-types-AOE\"> </a>\n          </td>\n          <td>Ask at Order Entry</td>\n          <td>Ask at Order Entry</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  ASC\n            <a name=\"diagnosticreport-relevant-information-types-ASC\"> </a>\n          </td>\n          <td>Ask at Specimen Collection</td>\n          <td>Ask at Specimen Collection</td>\n        </tr>\n        <tr>\n          <td>1</td>\n          <td style=\"white-space:nowrap\">RSLT\n            <a name=\"diagnosticreport-relevant-information-types-RSLT\"> </a>\n          </td>\n          <td>Result</td>\n          <td>Result</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  MCS\n            <a name=\"diagnosticreport-relevant-information-types-MCS\"> </a>\n          </td>\n          <td>Micro Culture Status</td>\n          <td>Sub-type of RSLT (Result) This term identifies observations that give overall culture outcome, when no specific organism is being named.</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  MID\n            <a name=\"diagnosticreport-relevant-information-types-MID\"> </a>\n          </td>\n          <td>Micro Isolate Descriptor</td>\n          <td>Sub-type of RSLT (Result) This term identifies any other observations about the isolate.</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  MIG\n            <a name=\"diagnosticreport-relevant-information-types-MIG\"> </a>\n          </td>\n          <td>Micro Isolate Growth Quantity</td>\n          <td>Sub-type of RSLT (Result) This term identifies growth levels of an isolate – can be numeric or categorical.</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  MIN\n            <a name=\"diagnosticreport-relevant-information-types-MIN\"> </a>\n          </td>\n          <td>Micro Isolate Name</td>\n          <td>NSub-type of RSLT (Result) This term identifies observations that name a specific organism either at the species or the genus level.</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  MOD\n            <a name=\"diagnosticreport-relevant-information-types-MOD\"> </a>\n          </td>\n          <td>Micro Other Descriptor</td>\n          <td>Sub-type of RSLT (Result) This term identifies observations that do not fit the culture status, but is not at the isolate level.</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  MSS\n            <a name=\"diagnosticreport-relevant-information-types-MSS\"> </a>\n          </td>\n          <td>Micro Sample Stain</td>\n          <td>Sub-type of RSLT (Result) This term identifies observations on gram stains (and other stains or smears) on the clinical sample.</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  SUP\n            <a name=\"diagnosticreport-relevant-information-types-SUP\"> </a>\n          </td>\n          <td>Supplemental Result</td>\n          <td>Supplemental Result</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  SUR\n            <a name=\"diagnosticreport-relevant-information-types-SUR\"> </a>\n          </td>\n          <td>Susceptibility Related</td>\n          <td>Susceptibility Related</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  UNSP\n            <a name=\"diagnosticreport-relevant-information-types-UNSP\"> </a>\n          </td>\n          <td>Unspecified</td>\n          <td>Unspecified</td>\n        </tr>\n        <tr>\n          <td>1</td>\n          <td style=\"white-space:nowrap\">SCI\n            <a name=\"diagnosticreport-relevant-information-types-SCI\"> </a>\n          </td>\n          <td>Supporting Clinical Information</td>\n          <td>Supporting Clinical Information</td>\n        </tr>\n        <tr>\n          <td>2</td>\n          <td style=\"white-space:nowrap\">  PHX\n            <a name=\"diagnosticreport-relevant-information-types-PHX\"> </a>\n          </td>\n          <td>Patient History</td>\n          <td>Historical patient data</td>\n        </tr>\n      </table>\n    </div>"^^rdf:XMLLiteral ]
  ] ; # 
