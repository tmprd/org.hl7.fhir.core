       ] [
         fhir:code [
           fhir:v "Reference"^^xsd:anyURI ;
           fhir:l fhir:Reference
         ] ;
         fhir:targetProfile ( [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Resource"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/StructureDefinition/Resource>
         ] )
       ] ) ;
       fhir:isSummary [ fhir:v true ]
     ] )
  ] . # 

