@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sct: <http://snomed.info/id/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

# This example where a patient reports is not taking now but will be taking in future

<http://hl7.org/fhir/MedicationStatement/example010> a fhir:MedicationStatement ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "example010"] ; # 
  fhir:status [ fhir:v "recorded"] ; # 
  fhir:medication [
     fhir:concept [
       fhir:coding ( [
         a sct:787481004 ;
         fhir:system [
           fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
           fhir:l <http://snomed.info/sct>
         ] ;
         fhir:code [ fhir:v "787481004" ] ;
         fhir:display [ fhir:v "No known medications" ]
       ] )
     ] # Linked to a RESOURCE Medication
  ] ; # 
  fhir:subject [
     fhir:l <http://hl7.org/fhir/Patient/pat1> ;
     fhir:reference [ fhir:v "Patient/pat1" ] ;
     fhir:display [ fhir:v "Donald Duck" ]
  ] ; # 
  fhir:effective [
     a fhir:DateTime ;
     fhir:v "2015-01-23"^^xsd:date
  ] ; # 
  fhir:dateAsserted [ fhir:v "2015-02-22"^^xsd:date] ; # 
  fhir:informationSource ( [
     fhir:l <http://hl7.org/fhir/Practitioner/example> ;
     fhir:reference [ fhir:v "Practitioner/example" ]
  ] ) ; # 
  fhir:note ( [
     fhir:text [ fhir:v "No known medications for the patient." ]
  ] ) . # 

<http://hl7.org/fhir/Patient/pat1> a fhir:Patient .

<http://hl7.org/fhir/Practitioner/example> a fhir:Practitioner .

# -------------------------------------------------------------------------------------

