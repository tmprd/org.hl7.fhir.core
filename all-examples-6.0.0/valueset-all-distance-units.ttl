     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: ValueSet all-distance-units</b>\n      </p>\n      <a name=\"all-distance-units\"> </a>\n      <a name=\"hcall-distance-units\"> </a>\n      <ul>\n        <li>Include codes from\n          <a href=\"http://unitsofmeasure.org\">\n            <code>http://unitsofmeasure.org</code>\n          </a>\n          <span title=\"Version is not explicitly stated. No matching Code System found\"> version Not Stated (use latest from terminology server)</span> where canonical  = m (m)\n        </li>\n      </ul>\n    </div>"^^rdf:XMLLiteral ]
