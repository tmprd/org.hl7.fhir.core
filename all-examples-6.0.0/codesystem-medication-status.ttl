     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: CodeSystem medication-status</b>\n      </p>\n      <a name=\"medication-status\"> </a>\n      <a name=\"hcmedication-status\"> </a>\n      <p>This case-sensitive code system \n        <code>http://hl7.org/fhir/CodeSystem/medication-status</code> defines the following codes:\n      </p>\n      <table class=\"codes\">\n        <tr>\n          <td style=\"white-space:nowrap\">\n            <b>Code</b>\n          </td>\n          <td>\n            <b>Display</b>\n          </td>\n          <td>\n            <b>Definition</b>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">active\n            <a name=\"medication-status-active\"> </a>\n          </td>\n          <td>Active</td>\n          <td>The medication record is current and is appropriate for reference in new instances.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">inactive\n            <a name=\"medication-status-inactive\"> </a>\n          </td>\n          <td>Inactive</td>\n          <td>The medication record is not current and is not is appropriate for reference in new instances.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">entered-in-error\n            <a name=\"medication-status-entered-in-error\"> </a>\n          </td>\n          <td>Entered in Error</td>\n          <td>The medication record was created erroneously and is not appropriated for reference in new instances.</td>\n        </tr>\n      </table>\n    </div>"^^rdf:XMLLiteral ]
  ] ; # 
