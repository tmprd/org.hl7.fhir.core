     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: ValueSet distance-units</b>\n      </p>\n      <a name=\"distance-units\"> </a>\n      <a name=\"hcdistance-units\"> </a>\n      <ul>\n        <li>Include these codes as defined in \n          <a href=\"http://unitsofmeasure.org\">\n            <code>http://unitsofmeasure.org</code>\n          </a>\n          <span title=\"Version is not explicitly stated. No matching Code System found\"> version Not Stated (use latest from terminology server)</span>\n          <table class=\"none\">\n            <tr>\n              <td style=\"white-space:nowrap\">\n                <b>Code</b>\n              </td>\n              <td>\n                <b>Display</b>\n              </td>\n            </tr>\n            <tr>\n              <td>nm</td>\n              <td>nanometers</td>\n            </tr>\n            <tr>\n              <td>um</td>\n              <td>micrometers</td>\n            </tr>\n            <tr>\n              <td>mm</td>\n              <td>millimeters</td>\n            </tr>\n            <tr>\n              <td>m</td>\n              <td>meters</td>\n            </tr>\n            <tr>\n              <td>km</td>\n              <td>kilometers</td>\n            </tr>\n          </table>\n        </li>\n      </ul>\n    </div>"^^rdf:XMLLiteral ]
