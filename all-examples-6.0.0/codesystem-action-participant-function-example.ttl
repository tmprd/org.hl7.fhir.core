     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: CodeSystem action-participant-function-example</b>\n      </p>\n      <a name=\"action-participant-function-example\"> </a>\n      <a name=\"hcaction-participant-function-example\"> </a>\n      <p>This case-sensitive code system \n        <code>http://hl7.org/fhir/action-participant-function-example</code> defines the following codes:\n      </p>\n      <table class=\"codes\">\n        <tr>\n          <td style=\"white-space:nowrap\">\n            <b>Code</b>\n          </td>\n          <td>\n            <b>Display</b>\n          </td>\n          <td>\n            <b>Definition</b>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">performer\n            <a name=\"action-participant-function-example-performer\"> </a>\n          </td>\n          <td>Performer</td>\n          <td>The participant is the performer of the action.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">author\n            <a name=\"action-participant-function-example-author\"> </a>\n          </td>\n          <td>Author</td>\n          <td>The participant is the author of the result of the action.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">reviewer\n            <a name=\"action-participant-function-example-reviewer\"> </a>\n          </td>\n          <td>Reviewer</td>\n          <td>The participant is reviewing the result of the action.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">witness\n            <a name=\"action-participant-function-example-witness\"> </a>\n          </td>\n          <td>Witness</td>\n          <td>The participant is a witness to the action being performed.</td>\n        </tr>\n      </table>\n    </div>"^^rdf:XMLLiteral ]
