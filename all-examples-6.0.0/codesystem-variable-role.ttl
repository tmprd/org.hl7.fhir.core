     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: CodeSystem variable-role</b>\n      </p>\n      <a name=\"variable-role\"> </a>\n      <a name=\"hcvariable-role\"> </a>\n      <p>This case-sensitive code system \n        <code>http://hl7.org/fhir/variable-role</code> defines the following codes:\n      </p>\n      <table class=\"codes\">\n        <tr>\n          <td style=\"white-space:nowrap\">\n            <b>Code</b>\n          </td>\n          <td>\n            <b>Display</b>\n          </td>\n          <td>\n            <b>Definition</b>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">population\n            <a name=\"variable-role-population\"> </a>\n          </td>\n          <td>Population</td>\n          <td>The group from which the observations were obtained.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">exposure\n            <a name=\"variable-role-exposure\"> </a>\n          </td>\n          <td>Exposure</td>\n          <td>An independant variable of primary interest.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">outcome\n            <a name=\"variable-role-outcome\"> </a>\n          </td>\n          <td>Outcome</td>\n          <td>A dependent variable.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">covariate\n            <a name=\"variable-role-covariate\"> </a>\n          </td>\n          <td>Covariate</td>\n          <td>A variable that influences the exposure or outcome.</td>\n        </tr>\n      </table>\n    </div>"^^rdf:XMLLiteral ]
