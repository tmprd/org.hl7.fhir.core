     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet device-specification-type</b></p><a name=\"device-specification-type\"> </a><a name=\"hcdevice-specification-type\"> </a><ul><li>Include these codes as defined in <a href=\"http://tx.fhir.org/r5\"><code>urn:iso:std:iso:11073:10101</code></a><span style=\"opacity: 0.5\" title=\"Version is not explicitly stated. When building this specification, the most recent version 2024-12-05 has been used\"> version ⏿2024-12-05</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528391\">528391</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_BP</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528404\">528404</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_BCA</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528425\">528425</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_HF_CARDIO</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528402\">528402</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_COAG</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528409\">528409</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_CGM</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528390\">528390</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_ECG</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528457\">528457</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_GENERIC</td><td>Indicates an agent that adheres to the IEEE 11073 standard, but for which no specification exists in a 104zz device specialization standard</td></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528401\">528401</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_GLUCOSE</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528455\">528455</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_AI_ACTIVITY_HUB</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528403\">528403</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_INSULIN_PUMP</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528405\">528405</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_PEFM</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528388\">528388</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_PULS_OXIM</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528397\">528397</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_CALC_PULM</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528408\">528408</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_SABTE</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528426\">528426</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_HF_STRENGTH</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528392\">528392</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_TEMP</td><td/></tr><tr><td><a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528399\">528399</a></td><td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_SCALE</td><td/></tr></table></li></ul></div>"^^rdf:XMLLiteral ]
