     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: CodeSystem devicealert-category</b>\n      </p>\n      <a name=\"devicealert-category\"> </a>\n      <a name=\"hcdevicealert-category\"> </a>\n      <p>This case-sensitive code system \n        <code>http://hl7.org/fhir/devicealert-category</code> defines the following codes:\n      </p>\n      <table class=\"codes\">\n        <tr>\n          <td style=\"white-space:nowrap\">\n            <b>Code</b>\n          </td>\n          <td>\n            <b>Display</b>\n          </td>\n          <td>\n            <b>Definition</b>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">environment\n            <a name=\"devicealert-category-environment\"> </a>\n          </td>\n          <td>Environment</td>\n          <td>Related to environmental conditions</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">respiratory\n            <a name=\"devicealert-category-respiratory\"> </a>\n          </td>\n          <td>Respiratory</td>\n          <td>Related to subject's respiratory function</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">maintenance\n            <a name=\"devicealert-category-maintenance\"> </a>\n          </td>\n          <td>Maintenance</td>\n          <td>Related to maintenance of the subject (e.g., a device)</td>\n        </tr>\n      </table>\n    </div>"^^rdf:XMLLiteral ]
