     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: CodeSystem medication-dose-aid</b>\n      </p>\n      <a name=\"medication-dose-aid\"> </a>\n      <a name=\"hcmedication-dose-aid\"> </a>\n      <p>This case-sensitive code system \n        <code>http://hl7.org/fhir/CodeSystem/medication-dose-aid</code> defines the following codes:\n      </p>\n      <table class=\"codes\">\n        <tr>\n          <td style=\"white-space:nowrap\">\n            <b>Code</b>\n          </td>\n          <td>\n            <b>Display</b>\n          </td>\n          <td>\n            <b>Definition</b>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">blisterpack\n            <a name=\"medication-dose-aid-blisterpack\"> </a>\n          </td>\n          <td>Blister Pack</td>\n          <td>A type of packaging in which a medication is sealed in plastic, often with a cardboard backing.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">dosette\n            <a name=\"medication-dose-aid-dosette\"> </a>\n          </td>\n          <td>Dosette</td>\n          <td>A box or tray that organizes mediations into separate compartments</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">sachets\n            <a name=\"medication-dose-aid-sachets\"> </a>\n          </td>\n          <td>Sachets</td>\n          <td>A small packet that contains medication for individual use.</td>\n        </tr>\n      </table>\n    </div>"^^rdf:XMLLiteral ]
