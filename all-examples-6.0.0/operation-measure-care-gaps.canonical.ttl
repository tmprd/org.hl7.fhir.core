     fhir:min [ fhir:v 0 ] ;
     fhir:max [ fhir:v "*" ] ;
     fhir:documentation [ fhir:v "The location(s) for which the gaps in care report will be run. This parameter is reflected in the location element of the resulting MeasureReport(s)." ] ;
