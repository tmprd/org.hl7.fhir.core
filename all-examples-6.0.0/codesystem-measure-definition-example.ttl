     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: CodeSystem measure-definition-example</b>\n      </p>\n      <a name=\"measure-definition-example\"> </a>\n      <a name=\"hcmeasure-definition-example\"> </a>\n      <p>This case-sensitive code system \n        <code>http://hl7.org/fhir/measure-definition-example</code> defines the following codes:\n      </p>\n      <table class=\"codes\">\n        <tr>\n          <td style=\"white-space:nowrap\">\n            <b>Code</b>\n          </td>\n          <td>\n            <b>Display</b>\n          </td>\n          <td>\n            <b>Definition</b>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">screening\n            <a name=\"measure-definition-example-screening\"> </a>\n          </td>\n          <td>Screening</td>\n          <td>Completion of a clinical or diagnostic tool used to identify people at risk of developing or having a certain disease or condition, even in the absence of symptoms.</td>\n        </tr>\n        <tr>\n          <td style=\"white-space:nowrap\">standardized-depression-screening-tool\n            <a name=\"measure-definition-example-standardized-depression-screening-tool\"> </a>\n          </td>\n          <td>Standardized Depression Screening Tool</td>\n          <td>A normalized and validated depression screening tool developed for the patient population in which it is being utilized.</td>\n        </tr>\n      </table>\n    </div>"^^rdf:XMLLiteral ]
