             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "international method of research" ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "experimental research" ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "experimental study" ]
         ] )
       ] [
         fhir:code [ fhir:v "SEVCO:01003" ] ;
         fhir:display [ fhir:v "randomized assignment" ] ;
         fhir:designation ( [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000550004" ] ;
             fhir:display [ fhir:v "Definition (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "An interventional study design in which an independent variable (an exposure or intervention) is prospectively assigned or modified by random chance to separate groups." ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "interventional research with randomized assignment" ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "randomized trial" ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "randomized controlled trial" ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "RCT" ]
         ] )
       ] [
         fhir:code [ fhir:v "SEVCO:01006" ] ;
         fhir:display [ fhir:v "simple randomization" ] ;
         fhir:designation ( [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000550004" ] ;
             fhir:display [ fhir:v "Definition (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "A randomized assignment in which each participant has the same prespecified likelihood of being assigned to a group as all other participants, independent of the assignment of any other participant." ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "unrestricted randomization" ]
         ] )
       ] [
         fhir:code [ fhir:v "SEVCO:01007" ] ;
         fhir:display [ fhir:v "stratified randomization" ] ;
         fhir:designation ( [
