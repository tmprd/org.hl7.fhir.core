  fhir:compose [
     fhir:include ( [
       fhir:system [
         fhir:v "https://fevir.net/sevco"^^xsd:anyURI ;
         fhir:l <https://fevir.net/sevco>
       ] ;
       fhir:version [ fhir:v "2.0" ] ;
       fhir:concept ( [
         fhir:code [ fhir:v "SEVCO:01001" ] ;
         fhir:display [ fhir:v "interventional research" ] ;
         fhir:designation ( [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000550004" ] ;
             fhir:display [ fhir:v "Definition (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "A study design in which an independent variable (an exposure or intervention) is prospectively assigned or modified by the investigator to evaluate a response in the dependent variable (an effect or outcome)." ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
