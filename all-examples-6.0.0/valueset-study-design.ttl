           ] ;
           fhir:value [ fhir:v "interventional study" ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "interventional study design" ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym (core metadata concept)" ]
           ] ;
           fhir:value [ fhir:v "interventional primary research" ]
         ] [
           fhir:use [
             fhir:system [
               fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
               fhir:l <http://snomed.info/sct>
             ] ;
