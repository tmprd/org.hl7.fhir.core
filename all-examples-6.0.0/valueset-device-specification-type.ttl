  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      <p class=\"res-header-id\">\n        <b>Generated Narrative: ValueSet device-specification-type</b>\n      </p>\n      <a name=\"device-specification-type\"> </a>\n      <a name=\"hcdevice-specification-type\"> </a>\n      <ul>\n        <li>Include these codes as defined in \n          <a href=\"http://tx.fhir.org/r5\">\n            <code>urn:iso:std:iso:11073:10101</code>\n          </a>\n          <span style=\"opacity: 0.5\" title=\"Version is not explicitly stated. When building this specification, the most recent version 2024-12-05 has been used\"> version ⏿2024-12-05</span>\n          <table class=\"none\">\n            <tr>\n              <td style=\"white-space:nowrap\">\n                <b>Code</b>\n              </td>\n              <td>\n                <b>Display</b>\n              </td>\n              <td>\n                <b>Definition</b>\n              </td>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528391\">528391</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_BP</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528404\">528404</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_BCA</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528425\">528425</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_HF_CARDIO</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528402\">528402</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_COAG</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528409\">528409</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_CGM</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528390\">528390</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_ECG</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528457\">528457</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_GENERIC</td>\n              <td>Indicates an agent that adheres to the IEEE 11073 standard, but for which no specification exists in a 104zz device specialization standard</td>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528401\">528401</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_GLUCOSE</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528455\">528455</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_AI_ACTIVITY_HUB</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528403\">528403</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_INSULIN_PUMP</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528405\">528405</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_PEFM</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528388\">528388</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_PULS_OXIM</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528397\">528397</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_CALC_PULM</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528408\">528408</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_SABTE</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528426\">528426</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_HF_STRENGTH</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528392\">528392</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_TEMP</td>\n              <td/>\n            </tr>\n            <tr>\n              <td>\n                <a href=\"http://tx.fhir.org/r5/ValueSet/MDC#MDC-528399\">528399</a>\n              </td>\n              <td style=\"color: #cccccc\">MDC_DEV_SPEC_PROFILE_SCALE</td>\n              <td/>\n            </tr>\n          </table>\n        </li>\n      </ul>\n    </div>"^^rdf:XMLLiteral ]
